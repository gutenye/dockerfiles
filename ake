#!/usr/bin/env bun

import { app, $ } from "@gutenye/script.js";

// `ake` is symlinked into sibling dirs (e.g. supercronic-ui); capture the
// caller's cwd so commands run in the invoking dir, not in dockerfiles/.
$.cwd(process.cwd());

app.cmd("publish", "Publish docker images").add(async () => {
  await $`docker compose build --push`;
});
